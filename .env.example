# All optional. Unset = fully offline, deterministic demo.
LEDGERSCOUT_SCENARIO=knitwear          # knitwear | sustainable_denim
USE_REAL_GEMINI=0
LEDGERSCOUT_TRENDS_LIVE=0
LEDGERSCOUT_RESALE_LIVE=0
LEDGERSCOUT_EUROSTAT_LIVE=0
LEDGERSCOUT_HF_LIVE=0

GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash

# Stripe payments (sandbox / test mode) — agent pays for premium datasets with real
# test-mode PaymentIntents. Off = local simulator (deterministic, no network).
# Verify connectivity: python3 -m ledger_scout.payments.verify_stripe
LEDGERSCOUT_STRIPE_LIVE=0
LEDGERSCOUT_CURRENCY=eur
STRIPE_SECRET_KEY=                      # sk_test_... from your Stripe sandbox

# Paid data APIs — optional enrichment (see docs/DATA_SOURCES.md)
# STATISTA_API_KEY=
